generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  LANDLORD
  TENANT
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum PropertyStatus {
  AVAILABLE
  RENTED
}

enum RentalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model User {
  id         String  @id @default(uuid())
  name       String
  email      String  @unique
  password   String
  phone      String?
  profileImg String? @map("profile_img")

  role   UserRole
  status UserStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  properties       Property[]
  tenantRequests   RentalRequest[] @relation("TenantRequests")
  landlordRequests RentalRequest[] @relation("LandlordRequests")
  payments         Payment[]
  reviews          Review[]

  @@map("users")
}

model Category {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  properties Property[]

  @@map("categories")
}

model Property {
  id String @id @default(uuid())

  landlordId String @map("landlord_id")
  categoryId String @map("category_id")

  title       String
  description String

  address String
  city    String

  rent            Decimal @db.Decimal(10, 2)
  securityDeposit Decimal @map("security_deposit") @db.Decimal(10, 2)

  bedrooms  Int
  bathrooms Int

  size Int

  images    String[]
  amenities String[]

  availableFrom DateTime @map("available_from")

  status PropertyStatus @default(AVAILABLE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  landlord User @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  category Category @relation(fields: [categoryId], references: [id])

  rentalRequests RentalRequest[]

  reviews Review[]

  @@map("properties")
}

model RentalRequest {
  id String @id @default(uuid())

  propertyId String @map("property_id")
  tenantId   String @map("tenant_id")
  landlordId String @map("landlord_id")

  moveInDate DateTime @map("move_in_date")

  duration Int

  message String?

  monthlyRent Decimal @map("monthly_rent") @db.Decimal(10, 2)

  status RentalRequestStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  tenant User @relation("TenantRequests", fields: [tenantId], references: [id], onDelete: Cascade)

  landlord User @relation("LandlordRequests", fields: [landlordId], references: [id], onDelete: Cascade)

  payment Payment?

  review Review?

  @@map("rental_requests")
}

model Payment {
  id String @id @default(uuid())

  rentalRequestId String @unique @map("rental_request_id")

  tenantId String @map("tenant_id")

  amount Decimal @db.Decimal(10, 2)

  currency String @default("usd")

  stripePaymentIntentId String @unique @map("stripe_payment_intent_id")

  stripeChargeId String? @map("stripe_charge_id")

  stripeCustomerId String? @map("stripe_customer_id")

  paymentMethod String? @map("payment_method")

  receiptUrl String? @map("receipt_url")

  status PaymentStatus @default(PENDING)

  paidAt DateTime? @map("paid_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rentalRequest RentalRequest @relation(fields: [rentalRequestId], references: [id], onDelete: Cascade)

  tenant User @relation(fields: [tenantId], references: [id])

  @@map("payments")
}

model Review {
  id String @id @default(uuid())

  propertyId String @map("property_id")

  tenantId String @map("tenant_id")

  rentalRequestId String @unique @map("rental_request_id")

  rating Int

  comment String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  tenant User @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  rentalRequest RentalRequest @relation(fields: [rentalRequestId], references: [id], onDelete: Cascade)

  @@map("reviews")
}
